# Get your API_ID and API_HASH from https://my.telegram.org
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# The name of the group to download from (must be exactly as it appears in Telegram)
GROUP_NAME=Your Group Name Here

# Optional: The ID of the specific subtopic (thread) you want to download from. 
# Leave blank to download from the entire group.
TOPIC_ID=

# The absolute or relative path where files will be saved
BASE_DOWNLOAD_DIR=./downloads
